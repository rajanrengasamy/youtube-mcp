{
  "name": "vidlens-mcp",
  "version": "0.4.0",
  "description": "VidLens MCP — The YouTube intelligence layer for AI agents. 37 tools, zero config, three-tier fallback.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "youtube-mcp": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "npm run build && node --test dist/test/**/*.test.js",
    "smoke": "node dist/scripts/smoke.js",
    "smoke:dry": "node dist/scripts/smoke.js --dry-run"
  },
  "keywords": [
    "mcp",
    "youtube",
    "model-context-protocol",
    "yt-dlp"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@google/genai": "^1.45.0",
    "@modelcontextprotocol/sdk": "^1.17.4",
    "execa": "^9.6.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2"
  }
}
